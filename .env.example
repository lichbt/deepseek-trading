# Oanda API Configuration
# Get these from https://developer.oanda.com
OANDA_ACCOUNT_ID=your_practice_account_id_here
OANDA_API_TOKEN=your_v20_api_token_here

# OpenRouter API Configuration (for auto research)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Telegram Bot Configuration (for notifications and status queries)
# 1. Create bot via @BotFather → get token
# 2. Start a chat with your bot → get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Example:
# OANDA_ACCOUNT_ID=101-001-12345678-001
# OANDA_API_TOKEN=abc123def456ghi789jkl012mno345pqr
# OPENROUTER_API_KEY=sk-or-v1-123abc...
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=987654321
